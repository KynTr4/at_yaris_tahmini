[Unit]
Description=AT Yaris Daily Shadow Pipeline
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=at_yaris
WorkingDirectory=/opt/at_yaris_tahmini
EnvironmentFile=/opt/at_yaris_tahmini/.env
ExecStart=/opt/at_yaris_tahmini/.venv/bin/python run_daily_pipeline.py
StandardOutput=append:/var/log/at_yaris_tahmini/daily.log
StandardError=append:/var/log/at_yaris_tahmini/daily.err.log
TimeoutStartSec=7200
