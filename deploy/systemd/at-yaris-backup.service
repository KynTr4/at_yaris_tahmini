[Unit]
Description=AT Yaris SQLite and Artifact Backup

[Service]
Type=oneshot
User=at_yaris
WorkingDirectory=/opt/at_yaris_tahmini
EnvironmentFile=/opt/at_yaris_tahmini/.env
ExecStart=/opt/at_yaris_tahmini/backup_daily.sh
StandardOutput=append:/var/log/at_yaris_tahmini/backup.log
StandardError=append:/var/log/at_yaris_tahmini/backup.err.log
TimeoutStartSec=3600
