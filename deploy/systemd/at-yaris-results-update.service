[Unit]
Description=AT Yaris Result Matching and Shadow Monitoring
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=at_yaris
WorkingDirectory=/opt/at_yaris_tahmini
EnvironmentFile=/opt/at_yaris_tahmini/.env
ExecStart=/opt/at_yaris_tahmini/.venv/bin/python run_results_update.py
StandardOutput=append:/var/log/at_yaris_tahmini/results.log
StandardError=append:/var/log/at_yaris_tahmini/results.err.log
TimeoutStartSec=3900
KillMode=control-group
