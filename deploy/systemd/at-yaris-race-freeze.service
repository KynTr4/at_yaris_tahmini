[Unit]
Description=AT Yaris Race-Level Final Prediction Freeze
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=at_yaris
WorkingDirectory=/opt/at_yaris_tahmini
EnvironmentFile=/opt/at_yaris_tahmini/.env
ExecStart=/opt/at_yaris_tahmini/.venv/bin/python run_race_freeze.py
StandardOutput=append:/var/log/at_yaris_tahmini/race-freeze.log
StandardError=append:/var/log/at_yaris_tahmini/race-freeze.err.log
TimeoutStartSec=3900
KillMode=control-group
