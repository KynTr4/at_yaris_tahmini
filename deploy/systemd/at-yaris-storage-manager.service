[Unit]
Description=AT Yaris Storage Manager — disk temizliği ve SQLite bakımı
After=network.target

[Service]
Type=oneshot
User=at_yaris
WorkingDirectory=/opt/at_yaris_tahmini
EnvironmentFile=/opt/at_yaris_tahmini/.env
ExecStart=/opt/at_yaris_tahmini/.venv/bin/python storage_manager.py --delete
StandardOutput=append:/var/log/at_yaris_tahmini/storage-manager.log
StandardError=append:/var/log/at_yaris_tahmini/storage-manager.err.log
TimeoutStartSec=3600
